# === Telegram User Account (Telethon) — для чтения сообщений ===
TELEGRAM_API_ID=your_api_id
TELEGRAM_API_HASH=your_api_hash
TELEGRAM_PHONE=+79001234567
# Путь к файлу сессии (по умолчанию session.session)
TELEGRAM_SESSION_NAME=session

# === Telegram Bot — для отправки итогов ===
TELEGRAM_BOT_TOKEN=your_bot_token

# === OpenRouter ===
OPENROUTER_API_KEY=your_openrouter_api_key
OPENROUTER_MODEL=google/gemini-2.5-flash-preview

# === Куда отправлять итоговое сообщение (Chat ID или @username) ===
TARGET_CHAT_ID=@your_channel_or_user_id

# === Чаты для сбора сообщений (через запятую: username или числовой ID) ===
# Пример: @mychat1,-1001234567890,@somegroup
SOURCE_CHATS=@chat1,@chat2,-1001234567890

# === Расписание ===
# День недели для автоматической отправки (0=пн ... 6=вс)
SCHEDULE_DAY_OF_WEEK=6
# Час UTC для отправки (например, 9 = 09:00 UTC)
SCHEDULE_HOUR=9

# === Промпт ===
# Можно оставить пустым — тогда используется дефолтный из prompts/summary_prompt.txt
CUSTOM_PROMPT=
